<?xml version="1.0" encoding="utf-8"?>
<!-- Efek akrilik (acrylic/frosted glass) untuk bottom sheet dialog.
     Layer:
     1. Base: warna semi-opaque utama (glass_overlay_bg)
     2. Sheen: gradient highlight di bagian atas → efek cahaya/depth
     3. Border: stroke tipis untuk definisi edge
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Base semi-opaque background -->
    <item>
        <shape>
            <solid android:color="@color/glass_overlay_bg" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- Layer 2: Top sheen highlight → efek cahaya akrilik -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="@color/acrylic_sheen_top"
                android:centerColor="@android:color/transparent"
                android:endColor="@android:color/transparent"
                android:centerY="0.3"
                android:type="linear" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- Layer 3: Subtle diagonal grain → efek tekstur akrilik -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="@color/acrylic_grain_a"
                android:centerColor="@android:color/transparent"
                android:endColor="@color/acrylic_grain_b"
                android:type="linear" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- Layer 4: Border stroke -->
    <item>
        <shape>
            <stroke android:width="0.5dp" android:color="@color/acrylic_border" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

</layer-list>
