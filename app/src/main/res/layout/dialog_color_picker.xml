<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_color_preview"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_hex_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="#FFFFFFFF"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="24dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
        <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="A" android:textStyle="bold" android:textColor="?android:attr/textColorSecondary"/>
        <SeekBar android:id="@+id/sb_alpha" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="255" android:progressTint="#9E9E9E" android:thumbTint="#9E9E9E"/>
        <TextView android:id="@+id/tv_alpha_val" android:layout_width="35dp" android:layout_height="wrap_content" android:text="255" android:gravity="end" android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
        <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="R" android:textStyle="bold" android:textColor="#F44336"/>
        <SeekBar android:id="@+id/sb_red" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="255" android:progressTint="#F44336" android:thumbTint="#F44336"/>
        <TextView android:id="@+id/tv_red_val" android:layout_width="35dp" android:layout_height="wrap_content" android:text="255" android:gravity="end" android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
        <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="G" android:textStyle="bold" android:textColor="#4CAF50"/>
        <SeekBar android:id="@+id/sb_green" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="255" android:progressTint="#4CAF50" android:thumbTint="#4CAF50"/>
        <TextView android:id="@+id/tv_green_val" android:layout_width="35dp" android:layout_height="wrap_content" android:text="255" android:gravity="end" android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="B" android:textStyle="bold" android:textColor="#2196F3"/>
        <SeekBar android:id="@+id/sb_blue" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="255" android:progressTint="#2196F3" android:thumbTint="#2196F3"/>
        <TextView android:id="@+id/tv_blue_val" android:layout_width="35dp" android:layout_height="wrap_content" android:text="255" android:gravity="end" android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

</LinearLayout>