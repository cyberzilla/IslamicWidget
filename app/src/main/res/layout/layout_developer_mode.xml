<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/glass_card_bg"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/glass_card_stroke"
    app:contentPadding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛠 Developer Mode: Tes Adzan"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:text="Jam"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/devSliderHour"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="23"
                android:progress="12"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorPrimary"
                android:progressBackgroundTint="@color/glass_slider_track"/>
            <TextView
                android:id="@+id/devTvHour"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="end"
                android:text="12"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:text="Menit"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/devSliderMinute"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="59"
                android:progress="30"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorPrimary"
                android:progressBackgroundTint="@color/glass_slider_track"/>
            <TextView
                android:id="@+id/devTvMinute"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="end"
                android:text="30"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.2"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Mute Sblm"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/devSliderBefore"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="2"
                android:progressTint="?android:attr/textColorSecondary"
                android:thumbTint="?android:attr/textColorSecondary"
                android:progressBackgroundTint="@color/glass_slider_track"/>
            <TextView
                android:id="@+id/devTvBefore"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="end"
                android:text="2 mnt"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Unmute Stlh"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/devSliderAfter"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="5"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorPrimary"
                android:progressBackgroundTint="@color/glass_slider_track"/>
            <TextView
                android:id="@+id/devTvAfter"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="end"
                android:text="5 mnt"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/devBtnCancel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:text="Batalkan Tes"
                android:textSize="12sp"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="?android:attr/textColorSecondary"
                android:textColor="?android:attr/textColorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/devBtnTest"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:text="Jalankan Tes"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="16dp"/>
        </LinearLayout>

        <!-- ==================== LOG AREA ==================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.3"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📋 Event Log"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/devBtnRefreshLog"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Refresh"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                app:strokeColor="?attr/colorPrimary"
                android:textColor="?attr/colorPrimary"
                android:layout_marginEnd="4dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/devBtnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Clear"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                app:strokeColor="?attr/colorError"
                android:textColor="?attr/colorError"/>
        </LinearLayout>

        <TextView
            android:id="@+id/devTvLogPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Path: ..."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="9sp"
            android:layout_marginBottom="8dp"
            android:fontFamily="monospace"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/devScrollLog"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#0AFFFFFF"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            android:fadeScrollbars="false"
            android:fillViewport="false">

            <TextView
                android:id="@+id/devTvLogContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(Belum ada log)"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3"
                android:padding="8dp"
                android:gravity="top"/>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>