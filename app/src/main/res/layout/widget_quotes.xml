<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glassmorphism"
    android:orientation="vertical">

    <ViewFlipper
        android:id="@+id/quote_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_quote_text_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:ellipsize="end"
                android:gravity="center"
                android:text="@string/quote_loading"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="italic"
                android:shadowColor="#CC000000"
                android:shadowDx="1.5"
                android:shadowDy="1.5"
                android:shadowRadius="3"/>

            <TextView
                android:id="@+id/tv_quote_reference_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/quote_default_reference"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:shadowColor="#CC000000"
                android:shadowDx="1.5"
                android:shadowDy="1.5"
                android:shadowRadius="3"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_quote_text_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:ellipsize="end"
                android:gravity="center"
                android:text="@string/quote_loading"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="italic"
                android:shadowColor="#CC000000"
                android:shadowDx="1.5"
                android:shadowDy="1.5"
                android:shadowRadius="3"/>

            <TextView
                android:id="@+id/tv_quote_reference_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/quote_default_reference"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:shadowColor="#CC000000"
                android:shadowDx="1.5"
                android:shadowDy="1.5"
                android:shadowRadius="3"/>
        </LinearLayout>

    </ViewFlipper>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4DFFFFFF"
        android:importantForAccessibility="no"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_quote_bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="6dp">

        <ImageButton
            android:id="@+id/btn_share_quote"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/quote_desc_share"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_share_modern"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_random_quote"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/quote_desc_random"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_sync_modern"
            app:tint="#FFFFFF" />
    </LinearLayout>

</LinearLayout>