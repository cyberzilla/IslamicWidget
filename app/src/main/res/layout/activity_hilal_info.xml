<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/glass_card_stroke"
        app:cardBackgroundColor="@color/glass_overlay_bg"
        android:clipToOutline="true"
        android:clipChildren="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="36dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="20dp">

                <!-- Section 1: Title -->
                <TextView
                    android:id="@+id/tv_hilal_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Section 2: Moon Phase Canvas -->
                <ImageView
                    android:id="@+id/iv_hilal_moon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Moon Phase" />

                <!-- Section 3: Tanggal Hijri & Masehi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_hilal_section"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_gregorian_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tv_hijri_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Section 4: Informasi Hilal (Scrollable) -->
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="280dp"
                    android:fadingEdge="vertical"
                    android:fadingEdgeLength="12dp"
                    android:requiresFadingEdge="vertical"
                    android:scrollbars="none">

                    <TextView
                        android:id="@+id/tv_hilal_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12.5sp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="?attr/colorOnSurface" />

                </ScrollView>

            </LinearLayout>

            <!-- Close button (sama persis dengan compass) -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_close_hilal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_close"
                app:tint="?attr/colorControlNormal"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/desc_close_button" />

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
